VITE_API_BASE_URL=/api/
# Real API host (used for WebSockets when VITE_API_BASE_URL is relative). Must match vite.config server.proxy target.
VITE_BACKEND_ORIGIN=http://167.86.71.135:8000
# Optional: full WebSocket origin, e.g. wss://api.example.com — overrides VITE_BACKEND_ORIGIN for WS only
# VITE_WS_BASE_URL=ws://167.86.71.135:8000
# If chat WS returns 404, paths may be under /api (default when VITE_API_BASE_URL is /api/). To force root /ws/… use:
# VITE_WS_PATH_PREFIX=
# Conference share links (used when sending links to mobile clients).
# VITE_CONFERENCE_WEB_BASE_URL=https://aprc.aprcrail.com
# VITE_CONFERENCE_LINK_PREFIX=APRC_CONF:
SITE_URL=https://example.com
